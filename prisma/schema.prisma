// Prisma Schema for 鼎立租售管理 Dingli Rental
// 修改後執行：npx prisma db push  (開發環境)
// 或產生 migration: npx prisma migrate dev --name <name>

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 後台管理員
model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 物件翻譯（英文 / 日文 / 未來其他語言）
model PropertyTranslation {
  id           Int      @id @default(autoincrement())
  propertyId   Int
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  locale       String   // 'en' | 'ja' (預留 'vi' / 'th' / 'id')
  title        String
  description  String?  @db.Text
  featureTags  Json     @default("[]") // 翻譯後的特色標籤陣列
  equipment    Json     @default("[]") // 翻譯後的設備清單
  furniture    Json     @default("[]") // 翻譯後的家具清單
  rentIncludes Json     @default("[]") // 翻譯後的租金包含項目
  tenantTypes  Json     @default("[]") // 翻譯後的身份要求
  region       String?  // 例：Taipei City
  district     String?  // 例：Zhongshan District
  street       String?
  community    String?
  typeMid      String?  // 例：Whole-Floor Residence
  buildingType String?  // 例：Apartment
  deposit      String?  // 例：Two months / 二ヶ月分
  minLease     String?  // 例：1 year / 1年
  direction    String?  // 例：South-facing / 南向
  sourceHash   String   // 來源中文內容的 hash，內容變更後重譯
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([propertyId, locale])
  @@index([locale])
}

// 物件
model Property {
  id              Int      @id @default(autoincrement())

  // 物件編號（[L][YY][MMDD][NNN]，9 碼，建立時自動產生並保證 unique）
  code            String?  @unique

  // 三層分類
  region          String   // 大：台北市/新北市/桃園市
  typeMid         String   // 中：套房/整層住家/別墅/店面/辦公室/其他（admin 可在 taxonomy 加新類型）
  buildingType    String?  // 小：公寓/透天厝/電梯大樓（admin 可在 taxonomy 加新類型）

  // 廣告類型描述（如：整層住家-透天厝）
  adType          String?

  // 地址
  city            String   // 縣市
  district        String   // 鄉鎮市區
  street          String?  // 街道
  lane            String?  // 巷
  alley           String?  // 弄
  number          String   // 號
  numberSub       String?  // 號之 X
  hideAddress     Boolean  @default(false)

  // 樓層
  floorType       String   @default("出租單層") // 出租單層/全棟
  floor           String?  // 樓
  floorSub        String?  // 樓之 X
  totalFloor      String?  // 總樓層

  // 社區
  community       String?

  // 格局
  rooms           Int      @default(0)
  livingRooms     Int      @default(0)
  bathrooms       Int      @default(0)
  balconies       Int      @default(0)
  openLayout      Boolean  @default(false)

  // 屋齡
  buildingAge     Int?
  ageUnknown      Boolean  @default(false)

  // 朝向
  direction       String?

  // 坪數
  usableArea      Float
  registeredArea  Float?

  // 設備（JSON 陣列）
  equipment       Json     @default("[]") // ["洗衣機","冰箱"...]
  furniture       Json     @default("[]") // ["床","衣櫃"...]
  hasElevator     Boolean  @default(false)

  // 身份要求 / 規範
  tenantTypes     Json     @default("[]") // ["學生","上班族","家庭"]
  cookingAllowed  Boolean  @default(true)
  petsAllowed     Boolean  @default(false)

  // 價格
  rent            Int      // 元/月
  deposit         String   @default("面議") // 面議/一個月/兩個月/三個月
  rentIncludes    Json     @default("[]") // ["管理費","清潔費"...]
  managementFee   Int?
  noManagementFee Boolean  @default(false)

  // 租期
  minLease        String   @default("一年") // 一年/半年/不限
  moveInDate      DateTime?
  anytimeMoveIn   Boolean  @default(false)

  // 特色描述
  title           String   // 廣告標題 6-30 字
  featureTags     Json     @default("[]") // ["社會住宅","租金補貼"...]
  description     String?  @db.Text

  // 圖片
  images          PropertyImage[]

  // 翻譯（en / ja）
  translations    PropertyTranslation[]

  // 瀏覽紀錄（後台統計用）
  views           PropertyView[]

  // 上下架
  status          String   @default("active") // active / inactive / pending
  featured        Boolean  @default(false)

  // 物件刊登狀態（顯示在卡片左上角的 badge）
  // active=出租中 / rented=已出租 / sold=售出 / closed=結束
  listingStatus   String   @default("active")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([region])
  @@index([typeMid])
  @@index([status])
  @@index([listingStatus])
}

// 物件圖片
model PropertyImage {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String   // 例：https://res.cloudinary.com/<cloud>/image/upload/properties/xxx.webp
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId])
}

// 首頁 Hero 輪播圖（最多 3 張，由後台管理）
model HeroSlide {
  id         Int      @id @default(autoincrement())
  imageUrl   String
  title      String?
  subtitle   String?
  ctaText    String?
  ctaLink    String?
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Hero 輪播設定
model HeroSettings {
  id          Int      @id @default(1)
  intervalSec Int      @default(5)
  updatedAt   DateTime @updatedAt
}

// 聯絡表單詢問紀錄（前台 /contact 送出後存入此表，後台 /admin/inquiries 處理）
model ContactInquiry {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String
  // userRole：'renter'（承租方）/ 'landlord'（出租方）；舊資料為 null
  userRole      String?
  // messengerType：'line' / 'whatsapp' / 'wechat'；舊資料為 null（此時 email 欄為傳統 email）。
  // 新版表單不再收 email；email 欄沿用作為「通訊軟體 ID / 號碼」儲存欄位以避免 rename 對舊資料的破壞。
  messengerType String?
  email         String?
  region        String?
  propertyType  String?
  budget        Int?
  message       String?  @db.Text
  status        String   @default("new") // new / contacted / closed
  notes         String?  @db.Text        // 業務內部備註
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// 站點內容（服務特色 / 人才招募 / 聯絡我們 等可編輯區塊）
model SiteContent {
  id        Int      @id @default(autoincrement())
  section   String   @unique // services / careers / contact / about
  data      Json
  updatedAt DateTime @updatedAt
}

// 物件瀏覽次數：以「(propertyId, ipHash, day)」三元組去重
// 同 IP 同一天進入同一物件詳細頁只計 1 次；建檔即視為 1 次瀏覽。
// 加 FK + onDelete Cascade：物件被刪除時自動清除歷史紀錄；
// 同時防止 API 接收到不存在的 propertyId 灌假資料（P2003 會擋下）。
model PropertyView {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ipHash     String   // sha256(salt + ip)，避免明文儲存 IP
  day        DateTime @db.Date // UTC 日期（去重粒度）
  createdAt  DateTime @default(now())

  @@unique([propertyId, ipHash, day])
  @@index([propertyId])
  @@index([day])
}

// 首頁訪客次數：同 IP 同一天進入首頁只計 1 次
model SiteVisit {
  id        Int      @id @default(autoincrement())
  ipHash    String
  day       DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([ipHash, day])
  @@index([day])
}
