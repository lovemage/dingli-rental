# PostgreSQL connection (Railway 提供)
# 本機開發可用 PostgreSQL，部署時 Railway 會自動注入
DATABASE_URL="postgresql://user:password@host:5432/dingli_rental?schema=public"

# JWT secret for admin auth (請改為長字串)
JWT_SECRET="dingli-please-change-this-to-a-long-random-string"

# 圖片上傳目錄 (Railway 部署時掛載 Volume 至此路徑)
UPLOAD_DIR="./public/uploads"

# 公開網址 (生產環境)
NEXT_PUBLIC_SITE_URL="https://dingli-rental.com"
